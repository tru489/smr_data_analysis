{{
/RawData currentfile /ASCII85Decode filter def
/Data RawData /FlateDecode filter def
/DeviceGray setcolorspace
<<
  /ImageType 1
  /Decode [0 1]
  /DataSource Data
  /Height 236
  /ImageMatrix [315 0 0 236 0 0]
  /Width 315
  /BitsPerComponent 8
>> image
} stopped {handleerror} if
  RawData flushfile
} exec
